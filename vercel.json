{
  "version": 2,
  "functions": {
    "api/divine.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/css/(.*)",  "dest": "/css/$1"  },
    { "src": "/js/(.*)",   "dest": "/js/$1"   },
    { "src": "/(.*)",      "dest": "/index.html" }
  ]
}
